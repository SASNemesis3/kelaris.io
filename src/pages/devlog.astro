---
import BaseLayout from '../layouts/BaseLayout.astro';

const updates = [
  ['Update 01', 'Project foundation', 'Kelaris moved from concept into active production with its visual direction, gameplay pillars, and long-term identity defined.'],
  ['Update 02', 'Official website and community launch', 'The public site and Discord are live, establishing a hub for updates, community growth, and future launch visibility.'],
  ['Update 03', 'Core systems development', 'Work continues on the foundations that power the colony, world simulation, progression flow, and long-form survival loop.']
];
---

<BaseLayout title="Kelaris Devlog | Official Website" description="Read development updates and public progress notes for Kelaris." activePage="devlog">
  <section class="page-hero compact">
    <div>
      <div class="eyebrow">Devlog</div>
      <h1>Public development updates for Kelaris.</h1>
      <p class="lead">This modular devlog foundation keeps the update trail professional now and prepares the site for Markdown-powered posts later.</p>
    </div>
  </section>

  <section class="timeline section-block">
    {updates.map(([date, title, body]) => (
      <article class="timeline-item">
        <div class="date">{date}</div>
        <strong>{title}</strong>
        <p>{body}</p>
      </article>
    ))}
  </section>
</BaseLayout>
