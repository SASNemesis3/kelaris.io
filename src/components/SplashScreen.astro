  @media (max-width: 700px) {
    .splash-v2-stage { min-height: min(600px, calc(100vh - 20px)); }
    .splash-v2-title { font-size: clamp(3.2rem, 16vw, 5.2rem); gap: 4px; }
    .splash-v2-subtitle { letter-spacing: 0.34em; }
    .splash-v2-anvil { transform: scale(0.78); }
  }

  @media (prefers-reduced-motion: reduce) {
    .splash-v2,
    .splash-v2.is-leaving,
    .splash-v2-storm,
    .splash-v2-bg::after,
    .splash-v2-ring,
    .splash-v2-shockwave,
    .splash-v2-studio,
    .splash-v2-anvil-wrap,
    .splash-v2-crack,
    .splash-v2-shards span,
    .splash-v2-title span,
    .splash-v2-subtitle,
    .splash-v2-loader-scan {
      animation: none;
    }
  }
</style>

<script is:inline>
  (() => {
    const splash = document.getElementById('splash-screen');
    const statusText = document.getElementById('splash-status-text');
    const statusPercent = document.getElementById('splash-status-percent');
    const loaderFill = document.getElementById('splash-loader-fill');

    if (!splash) return;

    const storageKey = 'kelarisSplashLastSeenDate';
    const todayKey = new Date().toLocaleDateString('en-CA');
    let lastSeenDate = null;

    try {
      lastSeenDate = window.localStorage.getItem(storageKey);
    } catch (error) {
      lastSeenDate = null;
    }

    if (lastSeenDate === todayKey) {
      splash.remove();
      return;
    }

    try {
      window.localStorage.setItem(storageKey, todayKey);
    } catch (error) {
      // If localStorage is unavailable, fall through and show the splash.
    }

    const fullAnimationMs = 5600;
    const fadeOutMs = 900;
    const safetyMaxMs = 11000;
    const startedAt = performance.now();
    let pageReady = document.readyState === 'complete';
    let closed = false;
    let progress = 0;
    let progressTimer;

    const messages = [
      'Forging identity',
      'Charging glass core',
      'Stress fracture detected',
      'Shattering limits',
      'Revealing Kelaris',
      'Experience ready'
    ];

    const setProgress = (value) => {
      progress = Math.max(progress, Math.min(100, value));
      const rounded = Math.floor(progress);

      if (statusPercent) statusPercent.textContent = `${rounded}%`;
      if (loaderFill) loaderFill.style.transform = `scaleX(${progress / 100})`;

      if (statusText) {
        const index = Math.min(messages.length - 1, Math.floor((rounded / 100) * messages.length));
        statusText.textContent = messages[index];
      }
    };

    const closeSplash = () => {
      if (closed) return;
      closed = true;
      window.clearInterval(progressTimer);
      setProgress(100);
      splash.classList.add('is-leaving');

      window.setTimeout(() => {
        splash.remove();
      }, fadeOutMs);
    };

    const tryFinish = () => {
      pageReady = true;
      const elapsed = performance.now() - startedAt;
      const remaining = Math.max(0, fullAnimationMs - elapsed);
      window.setTimeout(closeSplash, remaining);
    };

    progressTimer = window.setInterval(() => {
      const elapsed = performance.now() - startedAt;
      const animationProgress = Math.min(99, (elapsed / fullAnimationMs) * 100);
      const cap = pageReady ? 100 : 96;
      setProgress(Math.min(cap, animationProgress));
    }, 50);

    setProgress(0);

    if (document.readyState === 'complete') {
      tryFinish();
    } else {
      window.addEventListener('load', tryFinish, { once: true });
    }

    window.setTimeout(() => {
      pageReady = true;
      closeSplash();
    }, safetyMaxMs);
  })();
</script>
