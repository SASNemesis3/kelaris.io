<div class="splash-screen" id="splash-screen" aria-label="Kelaris loading screen">
  <div class="splash-shell">
    <div class="splash-orbit" aria-hidden="true"></div>
    <div class="splash-kicker">Glass Anvil Studio Presents</div>
    <div class="splash-title">Kelaris</div>

    <div class="splash-loader" aria-hidden="true">
      <div class="splash-loader-fill"></div>
      <div class="splash-loader-glow"></div>
    </div>

    <div class="splash-status">
      <span id="splash-status-text">Initializing colony systems</span>
      <span id="splash-status-percent">0%</span>
    </div>
  </div>
</div>

<script is:inline>
  const splash = document.getElementById('splash-screen');
  const splashStatusText = document.getElementById('splash-status-text');
  const splashStatusPercent = document.getElementById('splash-status-percent');

  if (splash) {
    const fullAnimationMs = 3600;
    const fadeOutMs = 700;
    const safetyMaxMs = 7000;
    const startedAt = performance.now();
    let hasClosed = false;
    let pageReady = document.readyState === 'complete';
    let visualProgress = 0;

    const loadingMessages = [
      'Initializing colony systems',
      'Loading production grid',
      'Calibrating orbital telemetry',
      'Warming Glass Anvil systems',
      'Preparing Kelaris interface',
      'Kelaris ready'
    ];

    const progressTimer = window.setInterval(() => {
      const elapsed = performance.now() - startedAt;
      const animationProgress = Math.min(99, Math.floor((elapsed / fullAnimationMs) * 100));
      const loadCap = pageReady ? 100 : 92;

      visualProgress = Math.min(loadCap, Math.max(visualProgress, animationProgress));

      if (splashStatusPercent) {
        splashStatusPercent.textContent = `${visualProgress}%`;
      }

      if (splashStatusText) {
        const messageIndex = Math.min(
          loadingMessages.length - 1,
          Math.floor((visualProgress / 100) * loadingMessages.length)
        );
        splashStatusText.textContent = loadingMessages[messageIndex];
      }
    }, 80);

    const closeSplash = () => {
      if (hasClosed) return;
      hasClosed = true;
      window.clearInterval(progressTimer);

      if (splashStatusPercent) {
        splashStatusPercent.textContent = '100%';
      }

      if (splashStatusText) {
        splashStatusText.textContent = 'Kelaris ready';
      }

      splash.classList.add('is-leaving');

      window.setTimeout(() => {
        splash.remove();
      }, fadeOutMs);
    };

    const tryCloseAfterReady = () => {
      pageReady = true;
      const elapsed = performance.now() - startedAt;
      const remainingAnimationTime = Math.max(0, fullAnimationMs - elapsed);
      window.setTimeout(closeSplash, remainingAnimationTime);
    };

    if (document.readyState === 'complete') {
      tryCloseAfterReady();
    } else {
      window.addEventListener('load', tryCloseAfterReady, { once: true });
    }

    window.setTimeout(() => {
      pageReady = true;
      closeSplash();
    }, safetyMaxMs);
  }
</script>
