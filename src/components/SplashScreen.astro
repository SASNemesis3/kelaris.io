    animation: loaderScan 1.15s ease-in-out infinite;
  }

  .splash-v2-status {
    position: absolute;
    bottom: clamp(34px, 6vh, 56px);
    width: min(560px, calc(100vw - 64px));
    display: flex;
    justify-content: space-between;
    gap: 18px;
    color: rgba(246,251,255,0.82);
    font-size: clamp(0.68rem, 1.4vw, 0.88rem);
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  @keyframes splashV2Enter { from { opacity: 0; } to { opacity: 1; } }
  @keyframes splashV2Exit { to { opacity: 0; transform: scale(1.025); filter: blur(14px); } }
  @keyframes stormDrift { to { transform: translate3d(-3%, 2%, 0); } }
  @keyframes starFall { to { background-position: -160px 520px; } }
  @keyframes ringSpin { to { transform: rotate(360deg); } }
  @keyframes ringCharge {
    0% { opacity: 0; transform: scale(0.72); }
    30% { opacity: 0.5; transform: scale(0.9); }
    62% { opacity: 1; transform: scale(1); }
    100% { opacity: 0.65; transform: scale(1.05); }
  }
  @keyframes shockwave {
    0%, 58% { opacity: 0; transform: scale(0.15); border-color: rgba(255,255,255,0); }
    64% { opacity: 1; border-color: rgba(255,255,255,0.75); box-shadow: 0 0 80px rgba(255,80,80,0.55); }
    100% { opacity: 0; transform: scale(6); border-color: rgba(255,255,255,0); }
  }
  @keyframes studioIntro {
    0% { opacity: 0; transform: translateY(18px); filter: blur(8px); }
    14%, 42% { opacity: 1; transform: translateY(0); filter: blur(0); }
    54%, 100% { opacity: 0; transform: translateY(-22px) scale(0.96); filter: blur(8px); }
  }
  @keyframes anvilSequence {
    0%, 12% { opacity: 0; transform: translateY(26px) scale(0.78); filter: blur(12px) drop-shadow(0 0 0 transparent); }
    24%, 54% { opacity: 1; transform: translateY(0) scale(1); filter: blur(0) drop-shadow(0 0 28px rgba(190,220,255,0.45)); }
    60% { opacity: 1; transform: translateY(-3px) scale(1.04); filter: blur(0) drop-shadow(0 0 64px rgba(255,80,80,0.68)); }
    66%, 100% { opacity: 0; transform: scale(1.45); filter: blur(14px) drop-shadow(0 0 90px rgba(255,80,80,0.4)); }
  }
  @keyframes crackFlash {
    0%, 44% { opacity: 0; height: 0; }
    50%, 60% { opacity: 1; height: 118px; }
    66%, 100% { opacity: 0; }
  }
  @keyframes shardBurst {
    0%, 57% { opacity: 0; transform: translate(-50%, -50%) scale(0.25) rotate(0); }
    62% { opacity: 1; }
    100% { opacity: 0.62; transform: translate(calc(-50% + var(--x)), calc(-50% + var(--y))) scale(1.12) rotate(var(--r)); }
  }
