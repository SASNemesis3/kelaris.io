<div class="splash-screen" id="splash-screen" aria-label="Kelaris loading screen" role="status" aria-live="polite">
  <div class="splash-shell">
    <div class="splash-orbit" aria-hidden="true"></div>
    <div class="splash-grid" aria-hidden="true"></div>

    <div class="splash-kicker">Glass Anvil Studio Presents</div>
    <div class="splash-title">Kelaris</div>
    <div class="splash-subtitle">Colony systems online</div>

    <div class="splash-loader" aria-hidden="true">
      <div class="splash-loader-fill" id="splash-loader-fill"></div>
      <div class="splash-loader-glow"></div>
    </div>

    <div class="splash-status">
      <span id="splash-status-text">Initializing colony systems</span>
      <span id="splash-status-percent">0%</span>
    </div>
  </div>
</div>

<style>
  .splash-screen {
    position: fixed;
    inset: 0;
    z-index: 99999;
    display: grid;
    place-items: center;
    padding: 24px;
    color: #f4f7fb;
    background:
      radial-gradient(circle at 50% 28%, rgba(136, 168, 255, 0.24), transparent 28%),
      radial-gradient(circle at 50% 64%, rgba(125, 240, 210, 0.12), transparent 30%),
      linear-gradient(180deg, #010307 0%, #050816 54%, #02040a 100%);
    opacity: 1;
    pointer-events: all;
    animation: splashEnter 0.45s ease-out both;
  }

  .splash-screen.is-leaving {
    pointer-events: none;
    animation: splashExit 0.8s ease-in forwards;
  }

  .splash-shell {
    position: relative;
    width: min(760px, 100%);
    overflow: hidden;
    padding: clamp(30px, 7vw, 62px);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 34px;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.04)),
      rgba(5, 8, 22, 0.82);
    box-shadow:
      0 34px 120px rgba(0, 0, 0, 0.68),
      inset 0 1px 0 rgba(255, 255, 255, 0.18);
    text-align: left;
  }

  .splash-orbit {
    position: absolute;
    width: 360px;
    height: 360px;
    right: -130px;
    top: -150px;
    border: 1px solid rgba(125, 240, 210, 0.28);
    border-radius: 999px;
    box-shadow: 0 0 70px rgba(125, 240, 210, 0.14);
    animation: splashSpin 5s linear infinite;
  }

  .splash-orbit::before,
  .splash-orbit::after {
    content: "";
    position: absolute;
    border-radius: inherit;
    border: 1px solid rgba(136, 168, 255, 0.18);
  }

  .splash-orbit::before { inset: 44px; }
  .splash-orbit::after { inset: 92px; }

  .splash-grid {
    position: absolute;
    inset: 0;
    opacity: 0.13;
    background-image:
      linear-gradient(rgba(255,255,255,0.18) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.18) 1px, transparent 1px);
    background-size: 36px 36px;
    mask-image: linear-gradient(180deg, transparent, #000 20%, #000 80%, transparent);
  }

  .splash-kicker,
  .splash-title,
  .splash-subtitle,
  .splash-loader,
  .splash-status {
    position: relative;
    z-index: 1;
  }

  .splash-kicker {
    color: #7df0d2;
    font-size: 0.86rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .splash-title {
    margin-top: 14px;
    font-size: clamp(4rem, 13vw, 9rem);
    line-height: 0.86;
    font-weight: 950;
    letter-spacing: -0.08em;
    text-transform: uppercase;
    text-shadow:
      0 0 26px rgba(136, 168, 255, 0.48),
      0 0 70px rgba(125, 240, 210, 0.20);
  }

  .splash-subtitle {
    margin-top: 16px;
    color: rgba(244, 247, 251, 0.74);
    font-size: 1rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .splash-loader {
    position: relative;
    height: 16px;
    margin-top: 36px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 999px;
    background: rgba(255,255,255,0.075);
  }

  .splash-loader-fill {
    height: 100%;
    width: 100%;
    transform: scaleX(0);
    transform-origin: left;
    border-radius: inherit;
    background: linear-gradient(90deg, #88a8ff, #7df0d2, #ffffff);
    box-shadow: 0 0 28px rgba(125, 240, 210, 0.45);
  }

  .splash-loader-glow {
    position: absolute;
    inset: -30px 0;
    width: 34%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.78), transparent);
    filter: blur(8px);
    animation: splashScan 1.25s ease-in-out infinite;
  }

  .splash-status {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    margin-top: 14px;
    color: rgba(244, 247, 251, 0.82);
    font-size: 0.86rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @keyframes splashEnter {
    from { opacity: 0; transform: scale(1.025); }
    to { opacity: 1; transform: scale(1); }
  }

  @keyframes splashExit {
    to { opacity: 0; transform: scale(1.035); filter: blur(12px); }
  }

  @keyframes splashSpin {
    to { transform: rotate(360deg); }
  }

  @keyframes splashScan {
    from { transform: translateX(-130%); }
    to { transform: translateX(330%); }
  }

  @media (max-width: 640px) {
    .splash-shell { padding: 28px; border-radius: 26px; }
    .splash-title { font-size: clamp(3.35rem, 18vw, 5rem); }
    .splash-status { font-size: 0.72rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .splash-screen,
    .splash-screen.is-leaving,
    .splash-orbit,
    .splash-loader-glow {
      animation: none;
    }
  }
</style>

<script is:inline>
  (() => {
    const splash = document.getElementById('splash-screen');
    const statusText = document.getElementById('splash-status-text');
    const statusPercent = document.getElementById('splash-status-percent');
    const loaderFill = document.getElementById('splash-loader-fill');

    if (!splash) return;

    const storageKey = 'kelarisSplashLastSeenDate';
    const todayKey = new Date().toLocaleDateString('en-CA');
    let lastSeenDate = null;

    try {
      lastSeenDate = window.localStorage.getItem(storageKey);
    } catch (error) {
      lastSeenDate = null;
    }

    if (lastSeenDate === todayKey) {
      splash.remove();
      return;
    }

    try {
      window.localStorage.setItem(storageKey, todayKey);
    } catch (error) {
      // If localStorage is unavailable, fall through and show the splash.
    }

    const fullAnimationMs = 4200;
    const fadeOutMs = 800;
    const safetyMaxMs = 9000;
    const startedAt = performance.now();
    let pageReady = document.readyState === 'complete';
    let closed = false;
    let progress = 0;
    let progressTimer;

    const messages = [
      'Initializing colony systems',
      'Loading production grid',
      'Calibrating orbital telemetry',
      'Warming Glass Anvil systems',
      'Preparing Kelaris interface',
      'Kelaris ready'
    ];

    const setProgress = (value) => {
      progress = Math.max(progress, Math.min(100, value));
      const rounded = Math.floor(progress);

      if (statusPercent) statusPercent.textContent = `${rounded}%`;
      if (loaderFill) loaderFill.style.transform = `scaleX(${progress / 100})`;

      if (statusText) {
        const index = Math.min(messages.length - 1, Math.floor((rounded / 100) * messages.length));
        statusText.textContent = messages[index];
      }
    };

    const closeSplash = () => {
      if (closed) return;
      closed = true;
      window.clearInterval(progressTimer);
      setProgress(100);
      splash.classList.add('is-leaving');

      window.setTimeout(() => {
        splash.remove();
      }, fadeOutMs);
    };

    const tryFinish = () => {
      pageReady = true;
      const elapsed = performance.now() - startedAt;
      const remaining = Math.max(0, fullAnimationMs - elapsed);
      window.setTimeout(closeSplash, remaining);
    };

    progressTimer = window.setInterval(() => {
      const elapsed = performance.now() - startedAt;
      const animationProgress = Math.min(99, (elapsed / fullAnimationMs) * 100);
      const cap = pageReady ? 100 : 94;
      setProgress(Math.min(cap, animationProgress));
    }, 50);

    setProgress(0);

    if (document.readyState === 'complete') {
      tryFinish();
    } else {
      window.addEventListener('load', tryFinish, { once: true });
    }

    window.setTimeout(() => {
      pageReady = true;
      closeSplash();
    }, safetyMaxMs);
  })();
</script>
