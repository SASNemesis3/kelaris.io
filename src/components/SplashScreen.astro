  .crack-a { transform: rotate(22deg); }
  .crack-b { transform: translateX(-38px) rotate(-18deg); animation-delay: 0.05s; }
  .crack-c { transform: translateX(46px) rotate(35deg); animation-delay: 0.1s; }

  .splash-v2-shards {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .splash-v2-shards span {
    position: absolute;
    left: 50%;
    top: 50%;
    width: clamp(20px, 3vw, 42px);
    height: clamp(32px, 4vw, 64px);
    opacity: 0;
    background:
      linear-gradient(135deg, rgba(255,255,255,0.95), rgba(125,240,210,0.24) 48%, rgba(136,168,255,0.55));
