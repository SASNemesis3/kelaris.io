<div class="splash-v2" id="splash-screen" aria-label="Kelaris loading screen" role="status" aria-live="polite">
  <div class="splash-v2-bg" aria-hidden="true">
    <div class="splash-v2-storm"></div>
    <div class="splash-v2-mountains splash-v2-mountains-back"></div>
    <div class="splash-v2-mountains splash-v2-mountains-front"></div>
    <div class="splash-v2-ground"></div>
  </div>

  <div class="splash-v2-ring" aria-hidden="true"></div>
  <div class="splash-v2-shockwave" aria-hidden="true"></div>

  <div class="splash-v2-stage">
    <div class="splash-v2-studio" aria-hidden="true">
      <span>Glass Anvil Studio</span>
      <small>Presents</small>
    </div>

    <div class="splash-v2-anvil-wrap" aria-hidden="true">
      <div class="splash-v2-anvil">
        <div class="splash-v2-anvil-top"></div>
        <div class="splash-v2-anvil-horn"></div>
        <div class="splash-v2-anvil-body"></div>
        <div class="splash-v2-anvil-foot"></div>
      </div>
      <div class="splash-v2-crack crack-a"></div>
      <div class="splash-v2-crack crack-b"></div>
      <div class="splash-v2-crack crack-c"></div>
    </div>

    <div class="splash-v2-shards" aria-hidden="true">
      <span style="--x:-340px;--y:-180px;--r:-34deg;--d:0ms"></span>
      <span style="--x:-250px;--y:130px;--r:22deg;--d:70ms"></span>
      <span style="--x:-160px;--y:-260px;--r:60deg;--d:120ms"></span>
      <span style="--x:-70px;--y:210px;--r:-18deg;--d:40ms"></span>
      <span style="--x:80px;--y:-230px;--r:38deg;--d:90ms"></span>
      <span style="--x:170px;--y:180px;--r:-52deg;--d:150ms"></span>
      <span style="--x:260px;--y:-150px;--r:28deg;--d:30ms"></span>
      <span style="--x:360px;--y:90px;--r:-26deg;--d:110ms"></span>
      <span style="--x:430px;--y:-280px;--r:48deg;--d:180ms"></span>
      <span style="--x:-420px;--y:260px;--r:-58deg;--d:190ms"></span>
    </div>

    <div class="splash-v2-title" aria-hidden="true">
      <span>K</span><span>E</span><span>L</span><span>A</span><span>R</span><span>I</span><span>S</span>
    </div>
    <div class="splash-v2-subtitle" aria-hidden="true">Colony systems online</div>

    <div class="splash-v2-loader" aria-hidden="true">
      <div class="splash-v2-loader-fill" id="splash-loader-fill"></div>
      <div class="splash-v2-loader-scan"></div>
    </div>

    <div class="splash-v2-status">
      <span id="splash-status-text">Forging identity</span>
      <span id="splash-status-percent">0%</span>
    </div>
  </div>
</div>

<style>
  .splash-v2 {
    position: fixed;
    inset: 0;
    z-index: 99999;
    display: grid;
    place-items: center;
    overflow: hidden;
    color: #f6fbff;
    background: #02040a;
    isolation: isolate;
    pointer-events: all;
    animation: splashV2Enter 0.35s ease-out both;
  }

  .splash-v2.is-leaving {
    pointer-events: none;
    animation: splashV2Exit 0.9s ease-in forwards;
  }

  .splash-v2-bg,
  .splash-v2-storm,
  .splash-v2-mountains,
  .splash-v2-ground,
  .splash-v2-ring,
  .splash-v2-shockwave {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .splash-v2-bg {
    z-index: -4;
    background:
      radial-gradient(circle at 50% 34%, rgba(148, 184, 255, 0.22), transparent 24%),
      radial-gradient(circle at 50% 60%, rgba(255, 70, 70, 0.12), transparent 32%),
      linear-gradient(180deg, #030710 0%, #07101e 42%, #02040a 100%);
  }

  .splash-v2-storm {
    opacity: 0.85;
    background:
      radial-gradient(ellipse at 40% 8%, rgba(255,255,255,0.16), transparent 18%),
      radial-gradient(ellipse at 68% 18%, rgba(120,165,255,0.18), transparent 20%),
      radial-gradient(ellipse at 25% 60%, rgba(255,55,55,0.08), transparent 30%),
      repeating-linear-gradient(115deg, transparent 0 28px, rgba(255,255,255,0.025) 29px 30px);
    filter: blur(0.2px);
    animation: stormDrift 12s linear infinite;
  }

  .splash-v2-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 12% 18%, rgba(255,255,255,0.88) 99%, transparent),
      radial-gradient(1px 1px at 82% 24%, rgba(255,255,255,0.58) 99%, transparent),
      radial-gradient(1.5px 1.5px at 44% 12%, rgba(255,255,255,0.76) 99%, transparent),
      radial-gradient(1px 1px at 66% 72%, rgba(255,255,255,0.40) 99%, transparent);
    background-size: 360px 360px;
    opacity: 0.55;
    animation: starFall 18s linear infinite;
  }

  .splash-v2-mountains {
    top: auto;
    bottom: 0;
    height: 42vh;
    background: linear-gradient(180deg, rgba(12,19,33,0), #050812 76%);
    clip-path: polygon(0 100%, 0 72%, 6% 50%, 12% 76%, 18% 34%, 25% 82%, 33% 44%, 39% 72%, 49% 28%, 58% 80%, 67% 36%, 75% 70%, 84% 30%, 93% 74%, 100% 44%, 100% 100%);
  }

  .splash-v2-mountains-back {
    opacity: 0.7;
    filter: blur(2px);
    transform: scaleX(1.1) translateY(18px);
  }

  .splash-v2-mountains-front {
    height: 34vh;
    opacity: 0.95;
