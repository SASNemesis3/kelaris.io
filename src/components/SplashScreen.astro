  .splash-v2-anvil-body {
    left: 122px;
    top: 58px;
    width: 94px;
    height: 76px;
    clip-path: polygon(15% 0, 85% 0, 100% 100%, 0 100%);
  }

  .splash-v2-anvil-foot {
    left: 78px;
    top: 126px;
    width: 190px;
    height: 34px;
    border-radius: 8px;
  }

  .splash-v2-crack {
    position: absolute;
    width: 2px;
    height: 118px;
