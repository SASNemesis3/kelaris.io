    0%, 61% { opacity: 0; transform: translateY(42px) scale(0.86); filter: blur(16px); }
    72%, 100% { opacity: 1; transform: translateY(0) scale(1); filter: blur(0); }
  }
  @keyframes subtitleReveal {
    0%, 72% { opacity: 0; transform: translateY(14px); }
    82%, 100% { opacity: 1; transform: translateY(0); }
