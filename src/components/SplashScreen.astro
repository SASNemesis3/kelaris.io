  .splash-v2-title span {
    display: inline-block;
    opacity: 0;
    transform: translateY(42px) scale(0.86);
    animation: titleReveal 5.6s cubic-bezier(.2,.8,.2,1) both;
  }

  .splash-v2-title span:nth-child(1) { animation-delay: 0ms; }
  .splash-v2-title span:nth-child(2) { animation-delay: 60ms; }
  .splash-v2-title span:nth-child(3) { animation-delay: 120ms; }
  .splash-v2-title span:nth-child(4) { animation-delay: 180ms; }
  .splash-v2-title span:nth-child(5) { animation-delay: 240ms; }
  .splash-v2-title span:nth-child(6) { animation-delay: 300ms; }
  .splash-v2-title span:nth-child(7) { animation-delay: 360ms; }

  .splash-v2-subtitle {
    position: absolute;
    top: calc(50% + clamp(56px, 10vw, 104px));
    color: #ff5d5d;
    font-size: clamp(0.7rem, 1.5vw, 1rem);
    font-weight: 900;
    letter-spacing: 0.62em;
    text-transform: uppercase;
    opacity: 0;
    animation: subtitleReveal 5.6s ease both;
  }

  .splash-v2-loader {
    position: absolute;
    bottom: clamp(62px, 10vh, 96px);
    width: min(560px, calc(100vw - 64px));
    height: 12px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.20);
    border-radius: 999px;
    background: rgba(255,255,255,0.075);
    box-shadow: 0 0 24px rgba(255,70,70,0.20);
  }

  .splash-v2-loader-fill {
    height: 100%;
    width: 100%;
    transform: scaleX(0);
    transform-origin: left;
    border-radius: inherit;
    background: linear-gradient(90deg, #ff4a4a, #ffffff, #7df0d2);
    box-shadow: 0 0 28px rgba(255,70,70,0.48);
  }

  .splash-v2-loader-scan {
    position: absolute;
    inset: -24px 0;
    width: 26%;
