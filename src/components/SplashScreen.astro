    box-shadow: 0 0 24px rgba(190,220,255,0.42);
    animation: shardBurst 5.6s cubic-bezier(.12,.84,.18,1) both;
    animation-delay: var(--d);
  }

  .splash-v2-title {
    position: absolute;
    display: flex;
    justify-content: center;
    gap: clamp(5px, 1.1vw, 16px);
    font-size: clamp(4rem, 13vw, 10rem);
    line-height: 0.9;
    font-weight: 950;
    letter-spacing: 0.02em;
    color: #eaf7ff;
    text-transform: uppercase;
    text-shadow:
      0 0 18px rgba(255,255,255,0.70),
