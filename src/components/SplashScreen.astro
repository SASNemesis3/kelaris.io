<div class="splash-screen" id="splash-screen" aria-label="Kelaris loading screen" role="status" aria-live="polite">
  <div class="splash-shell">
    <div class="splash-orbit" aria-hidden="true"></div>
    <div class="splash-grid" aria-hidden="true"></div>

    <div class="splash-kicker">Glass Anvil Studio Presents</div>
    <div class="splash-title">Kelaris</div>
    <div class="splash-subtitle">Colony systems online</div>

    <div class="splash-loader" aria-hidden="true">
      <div class="splash-loader-fill" id="splash-loader-fill"></div>
      <div class="splash-loader-glow"></div>
    </div>

    <div class="splash-status">
      <span id="splash-status-text">Initializing colony systems</span>
      <span id="splash-status-percent">0%</span>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const splash = document.getElementById('splash-screen');
    const statusText = document.getElementById('splash-status-text');
    const statusPercent = document.getElementById('splash-status-percent');
    const loaderFill = document.getElementById('splash-loader-fill');

    if (!splash) return;

    const fullAnimationMs = 4200;
    const fadeOutMs = 800;
    const safetyMaxMs = 9000;
    const startedAt = performance.now();
    let pageReady = document.readyState === 'complete';
    let closed = false;
    let progress = 0;

    const messages = [
      'Initializing colony systems',
      'Loading production grid',
      'Calibrating orbital telemetry',
      'Warming Glass Anvil systems',
      'Preparing Kelaris interface',
      'Kelaris ready'
    ];

    const setProgress = (value) => {
      progress = Math.max(progress, Math.min(100, value));
      const rounded = Math.floor(progress);

      if (statusPercent) statusPercent.textContent = `${rounded}%`;
      if (loaderFill) loaderFill.style.transform = `scaleX(${progress / 100})`;

      if (statusText) {
        const index = Math.min(messages.length - 1, Math.floor((rounded / 100) * messages.length));
        statusText.textContent = messages[index];
      }
    };

    const closeSplash = () => {
      if (closed) return;
      closed = true;
      window.clearInterval(progressTimer);
      setProgress(100);
      splash.classList.add('is-leaving');

      window.setTimeout(() => {
        splash.remove();
      }, fadeOutMs);
    };

    const tryFinish = () => {
      pageReady = true;
      const elapsed = performance.now() - startedAt;
      const remaining = Math.max(0, fullAnimationMs - elapsed);
      window.setTimeout(closeSplash, remaining);
    };

    const progressTimer = window.setInterval(() => {
      const elapsed = performance.now() - startedAt;
      const animationProgress = Math.min(99, (elapsed / fullAnimationMs) * 100);
      const cap = pageReady ? 100 : 94;
      setProgress(Math.min(cap, animationProgress));
    }, 50);

    setProgress(0);

    if (document.readyState === 'complete') {
      tryFinish();
    } else {
      window.addEventListener('load', tryFinish, { once: true });
    }

    window.setTimeout(() => {
      pageReady = true;
      closeSplash();
    }, safetyMaxMs);
  })();
</script>
